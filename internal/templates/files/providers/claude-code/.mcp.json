{
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": ["--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server"]
    },
    "codegraph": {
      "command": "codegraph",
      "args": ["serve", "--mcp"]
    },
    "dbhub": {
      "command": "npx",
      "args": ["-y", "@bytebase/dbhub"],
      "disabled": true
    }
  }
}
